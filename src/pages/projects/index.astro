---
import MainLayout from '../../components/MainLayout.astro';
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL;

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<MainLayout title="Projects | SEO JEYUN">
  <h1>Projects</h1>
  <p class="muted">Main projects and their progress.</p>

  <div style="display:grid; gap:24px; margin-top:24px;">
    {projects.map((project) => {
      const slug = project.id.replace(/\/index$/, '');
      return (
        <article
          style="
            border:1px solid #27304d;
            background:#121831;
            border-radius:18px;
            overflow:hidden;
          "
        >
          <div
            style="
              display:grid;
              grid-template-columns: 380px 1fr;
              align-items:stretch;
            "
          >
            <div style="background:#0f1530; min-height:260px;">
              {project.data.coverImage && (
                <img
                  src={project.data.coverImage}
                  alt={`${project.data.title} cover image`}
                  style="
                    width:100%;
                    height:100%;
                    object-fit:cover;
                    display:block;
                  "
                />
              )}
            </div>

            <div style="padding:24px 28px;">
              <div
                style="
                  display:flex;
                  justify-content:space-between;
                  gap:16px;
                  flex-wrap:wrap;
                  align-items:flex-start;
                "
              >
                <h2 style="margin:0; font-size:1.5rem;">
                  <a href={`${BASE}projects/${slug}/`}>{project.data.title}</a>
                </h2>
                <span class="muted">{project.data.pubDate.toISOString().slice(0, 10)}</span>
              </div>

              <p class="muted" style="margin-top:16px; font-size:1.05rem;">
                {project.data.description}
              </p>

              <p style="margin-top:18px; color:#7aa2ff;">
                Status: {project.data.status}
              </p>
            </div>
          </div>
        </article>
      );
    })}
  </div>
</MainLayout>