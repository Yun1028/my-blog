---
import MainLayout from '../../components/MainLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getCollection } from 'astro:content';

const studyItems = (await getCollection('study')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<MainLayout title="Study | SEO JEYUN">
  <h1>Study</h1>
  <p class="muted">
    Study reports and slide links.
  </p>

  {studyItems.map((item) => (
    <ContentCard
      href={`/study/${item.id}/`}
      title={item.data.title}
      description={item.data.description}
      date={item.data.pubDate.toISOString().slice(0, 10)}
      extra={item.data.ppt ? 'Slides available' : undefined}
    />
  ))}
</MainLayout>