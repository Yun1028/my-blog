---
const BASE = import.meta.env.BASE_URL;

const slides = [
  {
    type: 'video',
    src: `${BASE}home-slides/dragoon.mp4`,
    title: 'Dragoon Locomotion'
  },
  // 나중에 이런 식으로 추가
  // {
  //   type: 'video',
  //   src: `${BASE}home-slides/dragoon-demo.mp4`,
  //   title: 'Dragoon Locomotion Demo',
  // },
];
---

<section class="hero-carousel" data-carousel>
  <div class="carousel-frame">
    {slides.map((slide, index) => (
      <div
        class={`slide ${index === 0 ? 'active' : ''}`}
        data-slide
        data-type={slide.type}
        data-index={index}
      >
        {slide.type === 'image' ? (
          <img src={slide.src} alt={slide.alt ?? slide.title ?? `slide-${index}`} />
        ) : (
          <video
            src={slide.src}
            muted
            playsinline
            preload="metadata"
            controls
          />
        )}

        {slide.title && (
          <div class="slide-caption">
            <span>{slide.title}</span>
          </div>
        )}
      </div>
    ))}
  </div>

  <div class="dots" data-dots>
    {slides.map((_, index) => (
      <button
        class={`dot ${index === 0 ? 'active' : ''}`}
        type="button"
        aria-label={`Go to slide ${index + 1}`}
        data-dot
        data-index={index}
      />
    ))}
  </div>
</section>

<script>
  const root = document.querySelector('[data-carousel]');
  if (root) {
    const slides = Array.from(root.querySelectorAll('[data-slide]'));
    const dots = Array.from(root.querySelectorAll('[data-dot]'));

    let current = 0;
    let timer = null;

    const clearRunningMedia = () => {
      slides.forEach((slide) => {
        const video = slide.querySelector('video');
        if (video) {
          video.pause();
          video.currentTime = 0;
          video.onended = null;
        }
      });
    };

    const clearTimer = () => {
      if (timer) {
        clearTimeout(timer);
        timer = null;
      }
    };

    const setActive = (nextIndex) => {
      clearTimer();
      clearRunningMedia();

      current = nextIndex;

      slides.forEach((slide, i) => {
        slide.classList.toggle('active', i === current);
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === current);
      });

      const activeSlide = slides[current];
      const type = activeSlide?.dataset.type;

      if (type === 'image') {
        timer = setTimeout(() => {
          goNext();
        }, 5000);
      } else if (type === 'video') {
        const video = activeSlide.querySelector('video');
        if (video) {
          video.currentTime = 0;
          const playPromise = video.play();
          if (playPromise && typeof playPromise.catch === 'function') {
            playPromise.catch(() => {});
          }
          video.onended = () => {
            goNext();
          };
        }
      }
    };

    const goNext = () => {
      const next = (current + 1) % slides.length;
      setActive(next);
    };

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => setActive(index));
    });

    if (slides.length > 0) {
      setActive(0);
    }
  }
</script>

<style>
  .hero-carousel {
    margin-bottom: 2.5rem;
  }

  .carousel-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 24px;
    overflow: hidden;
    background: #11182f;
    border: 1px solid #27304d;
  }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  .slide img,
  .slide video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background: #11182f;
  }

  .slide-caption {
    position: absolute;
    left: 20px;
    top: 18px;
    background: rgba(10, 16, 32, 0.68);
    border: 1px solid rgba(122, 162, 255, 0.24);
    color: #f5f7ff;
    padding: 10px 14px;
    border-radius: 14px;
    font-weight: 700;
    font-size: 1.4rem;
  }

  .dots {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 18px;
  }

  .dot {
    width: 44px;
    height: 8px;
    border-radius: 999px;
    border: none;
    background: rgba(255, 255, 255, 0.18);
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .dot.active {
    background: #ffffff;
  }

  @media (max-width: 768px) {
    .carousel-frame {
      aspect-ratio: 16 / 10;
      border-radius: 18px;
    }

    .slide-caption {
      font-size: 1rem;
      left: 14px;
      top: 14px;
      padding: 8px 10px;
    }

    .dot {
      width: 28px;
      height: 7px;
    }
  }
</style>